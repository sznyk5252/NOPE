// ANTLR Parse Tree
digraph {
	fontname=monospace fontsize=12 label="Source Code:\l----------------------------------------\l'( ())'\l" labeljust=l labelloc=t
	0 [label=program fontcolor=black]
	1 [label=code fontcolor=black]
	0 -> 1
	2 [label=input fontcolor=black]
	1 -> 2
	3 [label="STR\n''( ())''" color=lightgreen fontcolor=black shape=box style=filled]
	2 -> 3
	4 [label=EOF color=lightgreen fontcolor=black shape=box style=filled]
	0 -> 4
}
