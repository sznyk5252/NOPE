	28 [label="LP\n'('" color=lightgreen fontcolor=black shape=box style=filled]
	26 -> 28
	29 [label=expr fontcolor=black]
	26 -> 29
	30 [label=input fontcolor=black]
	29 -> 30
	31 [label="STR\n''The program threw an exception before terminating''" color=lightgreen fontcolor=black shape=box style=filled]
	30 -> 31
	32 [label="RP\n')'" color=lightgreen fontcolor=black shape=box style=filled]
	26 -> 32
	33 [label=ws color=gainsboro fontcolor=gray]
	21 -> 33 [color=lightgray]
	34 [label="ENDL\n'\n'" color=lightgray fontcolor=gray shape=ellipse]
	33 -> 34 [color=lightgray]
	35 [label="RBRACE\n'}'" color=lightgreen fontcolor=black shape=box style=filled]
	19 -> 35
	36 [label=EOF color=lightgreen fontcolor=black shape=box style=filled]
	0 -> 36
