// ANTLR Parse Tree
digraph {
	fontname=monospace fontsize=12 label="Source Code:\l----------------------------------------\l# This is comment line \l" labeljust=l labelloc=t
	0 [label=program]
	1 [label=code]
	0 -> 1
	2 [label=comment]
	1 -> 2
	3 [label="# This is comment line "]
	2 -> 3
	4 [label=<EOF>]
	0 -> 4
}
