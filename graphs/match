// ANTLR Parse Tree
digraph {
	fontname=monospace fontsize=12 label="Source Code:\l----------------------------------------\lMATCH('-?[0-9]+\\.?[0-9]*')\l" labeljust=l labelloc=t
	0 [label=program]
	1 [label=code]
	0 -> 1
	2 [label=macro_call]
	1 -> 2
	3 [label=match_macro]
	2 -> 3
	4 [label=MATCH]
	3 -> 4
	5 [label="("]
	3 -> 5
	6 [label=expr]
	3 -> 6
	7 [label=input]
	6 -> 7
	8 [label="'-?[0-9]+\\.?[0-9]*'"]
	7 -> 8
	9 [label=")"]
	3 -> 9
	10 [label=<EOF>]
	0 -> 10
}
