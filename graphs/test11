// ANTLR Parse Tree
digraph {
	fontname=monospace fontsize=12 label="Source Code:\l----------------------------------------\lTHROWS(EXCEPTION)\l" labeljust=l labelloc=t
	0 [label=program]
	1 [label=tag]
	0 -> 1
	2 [label=tagname]
	1 -> 2
	3 [label=THROWS]
	2 -> 3
	4 [label="("]
	1 -> 4
	5 [label=arg]
	1 -> 5
	6 [label=arg_part]
	5 -> 6
	7 [label=input]
	6 -> 7
	8 [label=EXCEPTION]
	7 -> 8
	9 [label=")"]
	1 -> 9
	10 [label=<EOF>]
	0 -> 10
}
