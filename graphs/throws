// ANTLR Parse Tree
digraph {
	fontname=monospace fontsize=12 label="Source Code:\l----------------------------------------\lTHROWS(EXCEPTION)\l" labeljust=l labelloc=t
	0 [label=program]
	1 [label=code]
	0 -> 1
	2 [label=macro_call]
	1 -> 2
	3 [label=throws_macro]
	2 -> 3
	4 [label=THROWS]
	3 -> 4
	5 [label="("]
	3 -> 5
	6 [label=EXCEPTION]
	3 -> 6
	7 [label=")"]
	3 -> 7
	8 [label=<EOF>]
	0 -> 8
}
