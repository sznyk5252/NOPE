// ANTLR Parse Tree
digraph {
	fontname=monospace fontsize=12 label="Source Code:\l----------------------------------------\l\\# This is NOT comment line\l" labeljust=l labelloc=t
	0 [label=program]
	1 [label=code]
	0 -> 1
	2 [label=input_in_escape]
	1 -> 2
	3 [label="ESCCHAR\n'\\'" color=green shape=box]
	2 -> 3
	4 [label="COM\n'# This is NOT comment line'" color=green shape=box]
	2 -> 4
	5 [label=EOF color=green shape=box]
	0 -> 5
}
