// ANTLR Parse Tree
digraph {
	fontname=monospace fontsize=12 label="Source Code:\l----------------------------------------\l\# This is NOT comment line\l" labeljust=l labelloc=t
	0 [label=program]
	1 [label=code]
	0 -> 1
	2 [label=input]
	1 -> 2
	3 [label="\"]
	2 -> 3
	4 [label=comment]
	1 -> 4
	5 [label="# This is NOT comment line"]
	4 -> 5
	6 [label=<EOF>]
	0 -> 6
}
